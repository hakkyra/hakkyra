{
  "name": "hakkyra",
  "version": "0.1.0",
  "description": "Auto-generate GraphQL + REST APIs from PostgreSQL with Hasura-compatible configuration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hakkyra": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts dev",
    "start": "node dist/cli.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "graphql": "^16.13.1",
    "graphql-ws": "^6.0.7",
    "jose": "^6.2.1",
    "js-yaml": "^4.1.1",
    "kriti-lang": "^1.0.0",
    "mercurius": "^16.8.0",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "pg-listen": "^1.7.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "bullmq": "^5.71.0",
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
